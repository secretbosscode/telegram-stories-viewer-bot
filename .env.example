DEV_BOT_TOKEN=
PROD_BOT_TOKEN=

USERBOT_API_ID=
USERBOT_API_HASH=
USERBOT_PHONE_NUMBER=
USERBOT_PASSWORD=
USERBOT_PHONE_CODE=

BOT_ADMIN_ID=

# Optional legacy BTC fallback. Leave all of these blank for the normal
# Telegram Stars pay-per-result mode. Stars pricing is managed in /starsadmin
# and does not require any additional environment variables.
BTC_WALLET_ADDRESS=
# If one of BTC_XPUB, BTC_YPUB or BTC_ZPUB is set, it overrides the fixed
# address when legacy BTC mode is selected.
BTC_XPUB=
BTC_YPUB=
BTC_ZPUB=

# Optional: where to store error logs
LOG_FILE=/data/error.log
# Optional: enable verbose logging to /data/debug.log (set to true or 1)
DEBUG_LOG=
# Optional: skip activating Telegram stealth mode (set to true or 1)
DISABLE_STEALTH_MODE=
